# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# Database Configuration (Update with your SQL Server details)
# For SQL Server Express: Server=.\SQLEXPRESS;Database=OnlineQuiz;Integrated Security=true;MultipleActiveResultSets=true;TrustServerCertificate=true
# For SQL Server: Server=localhost;Database=OnlineQuiz;Integrated Security=true;MultipleActiveResultSets=true;TrustServerCertificate=true
ConnectionStrings__DefaultConnection=Server=.\SQLEXPRESS;Database=OnlineQuiz;Integrated Security=true;MultipleActiveResultSets=true;TrustServerCertificate=true

# JWT Configuration
JwtSettings__SecretKey=YourActualSuperSecretKeyThatIsAtLeast32CharactersLongAndRandomlyGenerated
JwtSettings__Issuer=OnlineQuizAPI
JwtSettings__Audience=OnlineQuizUsers
JwtSettings__AccessTokenExpirationInMinutes=60
JwtSettings__RefreshTokenExpirationInDays=7

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Optional: HTTPS Configuration
ASPNETCORE_URLS=https://localhost:5201;http://localhost:5200